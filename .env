# Devstack Configuration
DEVSTACK_VERSION=1.0.0

# MySQL Configuration
MYSQL_ROOT_PASSWORD=root

# Minio Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# CafeDebug API (Docker Hub)
# Set to true to include API in local-devstack startup
CAFEDEBUG_API_ENABLED=true

# Docker Hub image coordinates
CAFEDEBUG_API_IMAGE_REPOSITORY=jnathany/cafedebug-backend-api
CAFEDEBUG_API_IMAGE_TAG=latest

# API ports
CAFEDEBUG_API_PORT=8080
CAFEDEBUG_API_CONTAINER_PORT=8080

# Database settings used by containerized API
MYSQL_DATABASE=cafedebug-mysql-local

# Optional API settings
JWT_ISSUER=https://api.cafedebug.com.br
JWT_AUDIENCE=https://cafedebug.com.br
JWT_SIGNING_KEY=cafedebug-local-jwt-2026-dev-signing-key-7f9c2a1b5d3e8k4m
JWT_VALID_FOR_MINUTES=15
JWT_REFRESH_VALID_FOR_MINUTES=10080
